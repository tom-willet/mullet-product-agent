#!/bin/sh
set -eu

APP_ROOT="/opt/paige"
DEPLOY_USER="${deploy_user}"

apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y \
  ca-certificates \
  curl \
  git \
  openssl \
  docker.io \
  docker-compose-v2

systemctl enable docker
systemctl start docker
usermod -aG docker "$DEPLOY_USER" || true

# Keep SSH responsive on the 512MB plan by adding swap space.
if ! swapon --show | grep -q '/swapfile'; then
  if command -v fallocate >/dev/null 2>&1; then
    fallocate -l 2G /swapfile
  else
    dd if=/dev/zero of=/swapfile bs=1M count=2048
  fi
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
fi
grep -q '^/swapfile ' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
sysctl -w vm.swappiness=10
grep -q '^vm.swappiness=' /etc/sysctl.conf && sed -i -e 's/^vm.swappiness=.*/vm.swappiness=10/' /etc/sysctl.conf || echo 'vm.swappiness=10' >> /etc/sysctl.conf

mkdir -p "$APP_ROOT"
chown -R "$DEPLOY_USER:$DEPLOY_USER" "$APP_ROOT"

cat >/usr/local/bin/paige-deploy.sh <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="/opt/paige"
REPO_DIR="$APP_ROOT/openclaw"
ENV_FILE="$APP_ROOT/.env"
STATE_DIR="$APP_ROOT/state"
WORKSPACE_DIR="$APP_ROOT/workspace"
CONFIG_FILE="$STATE_DIR/openclaw.json"
DEPLOY_USER="${deploy_user}"
REPO_URL="${openclaw_repo_url}"
REPO_REF="${openclaw_repo_ref}"
OPENCLAW_IMAGE_DEFAULT="${openclaw_image}"

upsert_env() {
  local key="$1"
  local value="$2"
  if grep -q "^$${key}=" "$ENV_FILE"; then
    sed -i -e "s|^$${key}=.*|$${key}=$${value}|" "$ENV_FILE"
  else
    printf '%s=%s\n' "$key" "$value" >>"$ENV_FILE"
  fi
}

mkdir -p "$APP_ROOT" "$STATE_DIR" "$WORKSPACE_DIR"

if [[ ! -d "$REPO_DIR/.git" ]]; then
  rm -rf "$REPO_DIR"
  git clone --depth 1 --branch "$REPO_REF" "$REPO_URL" "$REPO_DIR"
else
  git -C "$REPO_DIR" fetch --all --prune
  git -C "$REPO_DIR" checkout "$REPO_REF"
  git -C "$REPO_DIR" pull --ff-only origin "$REPO_REF"
fi

if [[ ! -f "$ENV_FILE" ]]; then
  cat >"$APP_ROOT/.env.example" <<'ENV'
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_SIGNING_SECRET=
SLACK_TEAM_ID=T0123456789
ALLOWED_SLACK_USER_ID=U0123456789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CONFIG_DIR=/opt/paige/state
OPENCLAW_WORKSPACE_DIR=/opt/paige/workspace
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
CLAUDBOT_WEBHOOK_PORT=3000
CLAUDBOT_LOG_LEVEL=info
ENV
  chown "$DEPLOY_USER:$DEPLOY_USER" "$APP_ROOT/.env.example"
  chmod 600 "$APP_ROOT/.env.example"
  echo "Created $APP_ROOT/.env.example. Copy to $ENV_FILE and fill values."
  exit 1
fi

chmod 600 "$ENV_FILE"
upsert_env "OPENCLAW_CONFIG_DIR" "$STATE_DIR"
upsert_env "OPENCLAW_WORKSPACE_DIR" "$WORKSPACE_DIR"
upsert_env "OPENCLAW_GATEWAY_BIND" "lan"
upsert_env "OPENCLAW_GATEWAY_PORT" "18789"
upsert_env "OPENCLAW_BRIDGE_PORT" "18790"
upsert_env "OPENCLAW_IMAGE" "$OPENCLAW_IMAGE_DEFAULT"

CURRENT_TOKEN="$(grep '^OPENCLAW_GATEWAY_TOKEN=' "$ENV_FILE" | sed 's/^OPENCLAW_GATEWAY_TOKEN=//' || true)"
if [[ -z "$CURRENT_TOKEN" ]]; then
  CURRENT_TOKEN="$(openssl rand -hex 32)"
  upsert_env "OPENCLAW_GATEWAY_TOKEN" "$CURRENT_TOKEN"
fi

set -a
source "$ENV_FILE"
set +a

if [[ -z "$${ALLOWED_SLACK_USER_ID:-}" ]]; then
  echo "ALLOWED_SLACK_USER_ID is required in $ENV_FILE"
  exit 1
fi

cat >"$CONFIG_FILE" <<JSON
{
  "gateway": {
    "auth": {
      "token": "$${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "dmPolicy": "allowlist",
      "allowFrom": ["$${ALLOWED_SLACK_USER_ID}"],
      "groupPolicy": "disabled"
    }
  }
}
JSON

if [[ -n "$${OPENCLAW_IMAGE:-}" ]] && ! docker image inspect "$OPENCLAW_IMAGE" >/dev/null 2>&1; then
  docker pull "$OPENCLAW_IMAGE"
fi

ln -sfn "$ENV_FILE" "$REPO_DIR/.env"
docker compose -f "$REPO_DIR/docker-compose.yml" --env-file "$ENV_FILE" up -d openclaw-gateway
SCRIPT

chmod +x /usr/local/bin/paige-deploy.sh

cat >/etc/systemd/system/paige-claudbot.service <<'UNIT'
[Unit]
Description=Paige OpenClaw Service
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/paige-deploy.sh
ExecReload=/usr/local/bin/paige-deploy.sh
WorkingDirectory=/opt/paige

[Install]
WantedBy=multi-user.target
UNIT

cat >/usr/local/bin/paige-update.sh <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
/usr/local/bin/paige-deploy.sh
SCRIPT
chmod +x /usr/local/bin/paige-update.sh

systemctl daemon-reload
systemctl enable paige-claudbot
