aws_profile        = "mullet-dev"
aws_region         = "us-west-2"
availability_zone  = "us-west-2a"
ssh_public_key_path = "/Users/your-user/.ssh/id_ed25519.pub"

# Tighten this to your current public IP/CIDR when possible.
allowed_ssh_cidrs = ["0.0.0.0/0"]

allowed_http_cidrs = ["0.0.0.0/0"]

snapshot_time_utc = "07:00"

claudbot_repo_url = "https://github.com/openclaw/claudbot.git"
claudbot_repo_ref = "main"

deploy_user = "ubuntu"

monthly_budget_limit_usd = 10
budget_alert_emails      = ["you@example.com"]

attach_operator_user = true
operator_iam_user    = "mullet-dev"
